#!/bin/bash

BT_SVC=org.bluez
BT_ADAPTER=/org/bluez/hci0
BT_IFACE_ADAPTER=org.bluez.Adapter1
BT_IFACE_DEVICE=org.bluez.Device1

mac_to_path() { echo "$BT_ADAPTER/dev_${1//:/_}"; }

bt_connect()    { busctl --timeout=15 call $BT_SVC "$(mac_to_path "$1")" $BT_IFACE_DEVICE Connect 2>/dev/null; }
bt_disconnect() { busctl --timeout=5  call $BT_SVC "$(mac_to_path "$1")" $BT_IFACE_DEVICE Disconnect 2>/dev/null; }
bt_pair()       { busctl --timeout=30 call $BT_SVC "$(mac_to_path "$1")" $BT_IFACE_DEVICE Pair 2>/dev/null; }
bt_trust()      { busctl set-property  $BT_SVC "$(mac_to_path "$1")" $BT_IFACE_DEVICE Trusted b true 2>/dev/null; }
bt_remove()     { busctl --timeout=5  call $BT_SVC $BT_ADAPTER $BT_IFACE_ADAPTER RemoveDevice o "$(mac_to_path "$1")" 2>/dev/null; }
bt_power()      { busctl set-property  $BT_SVC $BT_ADAPTER $BT_IFACE_ADAPTER Powered b "$1" 2>/dev/null; }

# Fetch all bluetooth data in one dbus call
bt_data=$(busctl --json=short call $BT_SVC / \
    org.freedesktop.DBus.ObjectManager GetManagedObjects 2>/dev/null)
if [ -z "$bt_data" ]; then
    notify-send "Bluetooth" "Bluetooth service unavailable"
    exit 1
fi

bt_powered=$(echo "$bt_data" | jq -r \
    '.data[0]["/org/bluez/hci0"]["org.bluez.Adapter1"]["Powered"].data')

devices_json=$(echo "$bt_data" | jq '[
    .data[0] | to_entries[]
    | select(.key | startswith("/org/bluez/hci0/dev_"))
    | .value["org.bluez.Device1"] as $d
    | select($d != null)
    | {
        mac:       $d["Address"].data,
        name:      ($d["Alias"].data // $d["Name"].data // "Unknown"),
        paired:    ($d["Paired"].data // false),
        connected: ($d["Connected"].data // false),
        icon:      ($d["Icon"].data // "unknown")
      }
]')

build_menu() {
    if [ "$bt_powered" != "true" ]; then
        echo "[Power: OFF] Turn on"
        return
    fi

    echo "$devices_json" | jq -r '
        sort_by([if .connected then 0 elif .paired then 1 else 2 end, .name]) |
        [.[].name] as $names |
        .[] |
        .name as $n |
        (if .connected then "*" else " " end) as $st |
        ({"audio-headset":"H","audio-headphones":"H","audio-card":"S",
          "input-gaming":"G","computer":"C","phone":"P"}[.icon] // "-") as $ty |
        (.mac[-5:]) as $suf |
        ([$names[] | select(. == $n)] | length > 1) as $dup |
        if .paired | not then      "[ ?] \($n) (\($suf))"
        elif $dup then              "[\($st)\($ty)] \($n) (\($suf))"
        else                        "[\($st)\($ty)] \($n)" end
    '

    echo "[Scan] Search for devices"
    echo "[Power: ON] Turn off"
}

get_mac() {
    local search="$1"
    if [[ "$search" =~ \(([0-9A-F:]{5})\)$ ]]; then
        echo "$devices_json" | jq -r --arg s "${BASH_REMATCH[1]}" \
            '.[] | select(.mac | endswith($s)) | .mac' | head -1
    else
        echo "$devices_json" | jq -r --arg n "$search" \
            '.[] | select(.name == $n) | .mac' | head -1
    fi
}

handle_selection() {
    local selection="$1"

    case "$selection" in
        "[Power: ON] Turn off")
            if bt_power false; then
                notify-send "Bluetooth" "Powered off"
            else
                notify-send "Bluetooth" "Failed to power off"
            fi
            ;;
        "[Power: OFF] Turn on")
            if bt_power true; then
                notify-send "Bluetooth" "Powered on"
            else
                notify-send "Bluetooth" "Failed to power on"
            fi
            ;;
        "[Scan] Search for devices")
            notify-send -t 5000 "Bluetooth" "Scanning for 5 seconds..."
            busctl call $BT_SVC $BT_ADAPTER $BT_IFACE_ADAPTER StartDiscovery 2>/dev/null
            sleep 5
            busctl call $BT_SVC $BT_ADAPTER $BT_IFACE_ADAPTER StopDiscovery 2>/dev/null
            exec "$0"
            ;;
        "["*"] "*)
            local name status mac display_name action
            name=$(echo "$selection" | sed 's/\[.*\] //')
            status=$(echo "$selection" | grep -o '^\[[^]]*\]' | tr -d '[]')
            mac=$(get_mac "$name")
            display_name=$(echo "$name" | sed 's/ ([0-9A-F:]\{5\})$//')

            if [ -z "$mac" ]; then
                notify-send "Bluetooth" "Device not found"
                exit 1
            fi

            if echo "$status" | grep -q '\*'; then
                action=$(printf "Disconnect\nRemove (unpair)" | tofi --prompt-text "$display_name: ")
                case "$action" in
                    "Disconnect")
                        if bt_disconnect "$mac"; then
                            notify-send "Bluetooth" "Disconnected from $display_name"
                        else
                            notify-send "Bluetooth" "Failed to disconnect from $display_name"
                        fi
                        ;;
                    "Remove (unpair)")
                        if bt_remove "$mac"; then
                            notify-send "Bluetooth" "Removed $display_name"
                        else
                            notify-send "Bluetooth" "Failed to remove $display_name"
                        fi
                        ;;
                esac
            elif echo "$status" | grep -q '?'; then
                action=$(printf "Pair & Connect\nPair only" | tofi --prompt-text "$display_name: ")
                case "$action" in
                    "Pair & Connect")
                        notify-send "Bluetooth" "Pairing with $display_name..."
                        if bt_pair "$mac" && bt_trust "$mac" && bt_connect "$mac"; then
                            notify-send "Bluetooth" "Connected to $display_name"
                        else
                            notify-send "Bluetooth" "Failed to pair/connect to $display_name"
                        fi
                        ;;
                    "Pair only")
                        if bt_pair "$mac" && bt_trust "$mac"; then
                            notify-send "Bluetooth" "Paired with $display_name"
                        else
                            notify-send "Bluetooth" "Failed to pair with $display_name"
                        fi
                        ;;
                esac
            else
                notify-send "Bluetooth" "Connecting to $display_name..."
                if bt_connect "$mac"; then
                    notify-send "Bluetooth" "Connected to $display_name"
                else
                    notify-send "Bluetooth" "Failed to connect to $display_name"
                fi
            fi
            ;;
    esac
}

selection=$(build_menu | tofi --prompt-text "bt: ")
[ -n "$selection" ] && handle_selection "$selection"
